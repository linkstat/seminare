<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640.0" prefWidth="780.0" xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ar.com.hmu.controller.RedactarMemorandumController">
    <center>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>

            <Label text="Asunto:" style="-fx-text-fill: #555;"/>
            <TextField fx:id="asuntoTextField" promptText="Asunto del memorándum (máx. 255 caracteres)"/>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Destinatarios:" style="-fx-text-fill: #555;"/>
                <ComboBox fx:id="destinatariosComboBox" prefWidth="280" promptText="Seleccionar y agregar"/>
                <Button text="Agregar" onAction="#onAgregarDestinatario"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Quitar seleccionado" onAction="#onQuitarDestinatario"/>
            </HBox>
            <ListView fx:id="destinatariosSeleccionadosList" prefHeight="80"/>

            <Separator/>

            <HBox alignment="CENTER_LEFT" spacing="4">
                <Label text="Contenido:" style="-fx-text-fill: #555;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label text="Formato:" style="-fx-text-fill: #888; -fx-font-size: 11;"/>
                <Button text="B" onAction="#onBold" style="-fx-font-weight: bold;">
                    <tooltip><Tooltip text="Negrita"/></tooltip>
                </Button>
                <Button text="I" onAction="#onItalic" style="-fx-font-style: italic;">
                    <tooltip><Tooltip text="Itálica"/></tooltip>
                </Button>
                <Button text="H" onAction="#onHeading">
                    <tooltip><Tooltip text="Encabezado (H2)"/></tooltip>
                </Button>
                <Button text="•" onAction="#onListaNoOrdenada">
                    <tooltip><Tooltip text="Lista no ordenada"/></tooltip>
                </Button>
                <Button text="1." onAction="#onListaOrdenada">
                    <tooltip><Tooltip text="Lista ordenada"/></tooltip>
                </Button>
                <Separator orientation="VERTICAL"/>
                <Button text="Vista previa" onAction="#onVistaPrevia"/>
            </HBox>
            <TextArea fx:id="contenidoTextArea" wrapText="true" prefRowCount="14" VBox.vgrow="ALWAYS"
                      promptText="El contenido admite Markdown (máx. 8000 caracteres)."/>

            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Adjuntos (próximamente):" style="-fx-text-fill: #999; -fx-font-style: italic;"/>
                <Button text="Adjuntar plantilla..." disable="true"/>
            </HBox>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>
            <Button text="Cancelar" onAction="#onCancelar"/>
            <Button text="Guardar borrador" onAction="#onGuardarBorrador"/>
            <Button fx:id="enviarButton" text="Enviar" onAction="#onEnviar" defaultButton="true"/>
        </HBox>
    </bottom>
</BorderPane>
