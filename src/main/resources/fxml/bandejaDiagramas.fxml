<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="520.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ar.com.hmu.controller.BandejaDiagramasController"
            stylesheets="@../css/diagramacionServicio.css">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>
            <Label text="Consulta de Diagramas de Servicios"
                   style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Estado:"/>
            <ComboBox fx:id="estadoFiltroCombo" prefWidth="200"/>
            <Label text="Servicio:"/>
            <ComboBox fx:id="servicioFiltroCombo" prefWidth="190"/>
            <Button text="Refrescar" onAction="#onRefrescar"/>
            <Button text="Cerrar" onAction="#onCerrar" cancelButton="true"/>
        </HBox>
    </top>
    <center>
        <TableView fx:id="diagramasTable">
            <columns>
                <TableColumn fx:id="servicioCol" prefWidth="200" text="SERVICIO"/>
                <TableColumn fx:id="periodoCol" prefWidth="180" text="PERÍODO"/>
                <TableColumn fx:id="estadoCol" prefWidth="170" text="ESTADO"/>
                <TableColumn fx:id="actualizadoCol" prefWidth="140" text="ACTUALIZADO"/>
                <TableColumn fx:id="creadoPorCol" prefWidth="180" text="CREADO POR"/>
            </columns>
            <BorderPane.margin>
                <Insets bottom="6" left="10" right="10"/>
            </BorderPane.margin>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="4"/>
            </padding>
            <Label text="Doble click (o Abrir) para ver el diagrama completo."
                   styleClass="ayuda"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button fx:id="abrirButton" text="Abrir" onAction="#onAbrir" defaultButton="true"/>
        </HBox>
    </bottom>
</BorderPane>
